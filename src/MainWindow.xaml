<Window x:Class="Swyft.ServoProgrammer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Swyft.ServoProgrammer.ViewModels"
        Title="SWYFT Servo Programmer V2"
        Height="820" Width="1180" MinHeight="680" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Icon="Assets/swyft-logo.png"
        Background="{StaticResource WindowBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Border Grid.Row="0" Background="{StaticResource BrandBlue}">
            <Grid Margin="22,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="White" CornerRadius="8" Padding="14,9" VerticalAlignment="Center">
                        <Image Source="Assets/swyft-wordmark.png" Height="26" Stretch="Uniform" />
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Servo Programmer V2" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="SWYFT Robotics" Foreground="#CCEAFF" FontSize="11" />
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource StatusPill}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ConnDot" Width="10" Height="10" VerticalAlignment="Center" Fill="#FF6B6B" />
                        <TextBlock Text="{Binding ConnectionStateText}" Foreground="White" FontWeight="SemiBold"
                                   Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============ Body ============ -->
        <Grid Grid.Row="1" Margin="20,18,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="160" />
            </Grid.RowDefinitions>

            <!-- Connection bar -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="COM PORT" Style="{StaticResource Caption}" />
                        <ComboBox Width="150" Style="{StaticResource BrandCombo}"
                                  ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Bottom" Margin="0,0,16,0" Command="{Binding RefreshPortsCommand}" />

                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="BAUD" Style="{StaticResource Caption}" />
                        <ComboBox Width="110" Style="{StaticResource BrandCombo}"
                                  ItemsSource="{Binding AvailableBaudRates}" SelectedItem="{Binding BaudRate}" />
                    </StackPanel>

                    <Button Grid.Column="6" Content="{Binding ConnectButtonText}" Style="{StaticResource PrimaryButton}"
                            VerticalAlignment="Bottom" MinWidth="130" Command="{Binding ConnectCommand}" />
                </Grid>
            </Border>

            <!-- Main area: parameters (left) + travel range / options (right), split in half -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Parameters -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SERVO PARAMETERS" Style="{StaticResource SectionHeader}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ParameterViewModel}">
                                        <Border Padding="0,8" ToolTip="{Binding Description}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{StaticResource TextPrimary}" />
                                                    <TextBlock Text="{Binding Range}" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                                </StackPanel>

                                                <TextBox Grid.Column="1" Style="{StaticResource NumericBox}" Width="84"
                                                         VerticalAlignment="Center"
                                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Unit}" VerticalAlignment="Center"
                                                           MinWidth="30" Margin="8,0,0,0" Foreground="{StaticResource TextSecondary}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Right column -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Travel range -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="TRAVEL RANGE" Style="{StaticResource SectionHeader}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Total Range" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" />
                                        <TextBlock Text="0&#x2013;320&#x00b0;" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Style="{StaticResource NumericBox}" Width="70" VerticalAlignment="Center"
                                             Text="{Binding TotalRangeDegrees, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsRangeEditable}" />
                                    <TextBlock Grid.Column="2" Text="&#x00b0;" VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{StaticResource TextSecondary}" />
                                </Grid>
                                <TextBlock Text="Split evenly between left and right sides." Style="{StaticResource Caption}"
                                           Margin="0,6,0,12" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Margin="0,2,0,2"
                                          Content="Continuous rotation" IsChecked="{Binding ContinuousRotation}" />
                                <TextBlock Text="Sets left and right range to 255 for full-speed continuous rotation."
                                           Style="{StaticResource Caption}" />
                            </StackPanel>
                        </Border>

                        <!-- Options -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="OPTIONS" Style="{StaticResource SectionHeader}" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Margin="0,2,0,2"
                                          Content="Reverse direction" IsChecked="{Binding DirectionReverse}" />
                                <TextBlock Text="Swaps left and right. Off = default direction." Style="{StaticResource Caption}" Margin="0,0,0,10" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Margin="0,2,0,2"
                                          Content="Stall protection" IsChecked="{Binding StallProtection}" />
                                <TextBlock Text="Shuts off the servo if stalled for over 10 seconds to prevent damage."
                                           Style="{StaticResource Caption}" Margin="0,0,0,10" />

                                <CheckBox Style="{StaticResource ToggleSwitch}" Margin="0,2,0,2"
                                          Content="Ramp mode" IsChecked="{Binding SoftStart}" />
                                <TextBlock Text="Limits the initial current surge at startup."
                                           Style="{StaticResource Caption}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Actions bar -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,12">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Read Servo" Style="{StaticResource PrimaryButton}" MinWidth="140"
                            Margin="0,0,10,0" Command="{Binding ReadCommand}" />
                    <Button Content="Flash Servo" Style="{StaticResource PrimaryButton}" MinWidth="140"
                            Margin="0,0,24,0" Command="{Binding WriteCommand}" />
                    <Button Content="Set defaults" Style="{StaticResource SecondaryButton}" MinWidth="120"
                            Margin="0,0,10,0" Command="{Binding SetDefaultsCommand}"
                            ToolTip="Load the recommended default servo parameters into the form." />
                    <Button Content="USB driver" Style="{StaticResource SecondaryButton}" MinWidth="120"
                            Margin="0,0,10,0" Command="{Binding OpenDriverFolderCommand}"
                            ToolTip="Open the folder with the Silicon Labs CP210x USB driver to install it manually." />
                    <Button Content="User guide" Style="{StaticResource SecondaryButton}" MinWidth="120"
                            Command="{Binding ShowGuideCommand}" />
                </StackPanel>
            </Border>

            <!-- Activity log -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ACTIVITY LOG" Style="{StaticResource SectionHeader}" Margin="0,0,0,6" />
                    <ListBox x:Name="LogList" ItemsSource="{Binding LogEntries}" BorderThickness="0"
                             Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="False">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,1" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Focusable" Value="False" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:LogEntry}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource TextSecondary}"
                                               FontFamily="Consolas" Width="72" />
                                    <TextBlock Text="{Binding Message}" Foreground="{Binding Color}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ============ Status bar ============ -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0">
            <DockPanel Margin="22,8">
                <TextBlock DockPanel.Dock="Right" Text="115200 8-N-2 &#x2022; single-wire UART"
                           Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimary}"
                           FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
