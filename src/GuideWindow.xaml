<Window x:Class="Swyft.ServoProgrammer.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SWYFT Servo Programmer V2 - User Guide"
        Height="760" Width="720" MinHeight="500" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{StaticResource WindowBackground}">

    <Window.Resources>
        <Style x:Key="GuideBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="GuideTerm" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
        <Style x:Key="GuideStep" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BrandBlue}">
            <StackPanel Orientation="Horizontal" Margin="20,14" VerticalAlignment="Center">
                <Border Background="White" CornerRadius="8" Padding="9,3" VerticalAlignment="Center">
                    <TextBlock Text="SWYFT" FontWeight="Bold" FontSize="18" Foreground="{StaticResource BrandBlue}" />
                </Border>
                <TextBlock Text="User Guide" Foreground="White" FontSize="18" FontWeight="SemiBold"
                           Margin="14,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <TextBlock Style="{StaticResource GuideBody}"
                           Text="This guide explains the settings and functionality of the SWYFT Servo Programmer software." />

                <!-- Getting Started -->
                <Border Style="{StaticResource Card}" Margin="0,8,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="GETTING STARTED" />
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="1. Install drivers: " /><Run Text="Click &quot;USB driver&quot; in the action bar to open the folder with the bundled Silicon Labs CP210x driver. Right-click &quot;silabser.inf&quot; and choose Install (or run the included CP210x installer). This is only needed once per computer." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="2. Connect servo: " /><Run Text="Connect the servo to the programmer. Match the gray wire (servo side) to the white wire (programmer side), as shown below." /></TextBlock>
                        <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8"
                                Background="White" Padding="8" Margin="0,2,0,10" HorizontalAlignment="Left">
                            <StackPanel>
                                <Image Source="Assets/wiring-diagram.png" Stretch="Uniform" MaxWidth="420"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Text="USB-to-UART adapter wired to a SWYFT servo." Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="3. Device Manager: " /><Run Text="Open Device Manager in Windows." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="4. Find COM port: " /><Run Text="Under &quot;Ports (COM &amp; LPT)&quot;, identify the COM port assigned to the programmer." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="5. Open software: " /><Run Text="Launch the SWYFT Servo Programmer software." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="6. Select COM port: " /><Run Text="Choose the identified COM port at the top of the window (use Refresh or Auto-detect if needed) and click Connect." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="7. Read servo: " /><Run Text="Click &quot;Read Servo&quot; to retrieve the current settings. If the values don't populate, double-check the previous steps." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="8. Modify settings: " /><Run Text="Adjust the servo settings as needed (see explanations below)." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}"><Run FontWeight="SemiBold" Text="9. Flash servo: " /><Run Text="Click &quot;Flash Servo&quot; to save the new settings. A successful flash updates the activity log with the current time." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideStep}" Margin="0"><Run FontWeight="SemiBold" Text="10. Unplug: " /><Run Text="Disconnect the servo from the programmer." /></TextBlock>
                    </StackPanel>
                </Border>

                <!-- Setting Explanations -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SETTING EXPLANATIONS" />

                        <TextBlock Style="{StaticResource GuideTerm}" Text="PID coefficients" />
                        <TextBlock Style="{StaticResource GuideBody}" Text="These parameters fine-tune the servo's response characteristics." />
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="P (Proportional): " /><Run Text="How strongly the servo reacts to the error between its current and target position. Higher P = faster response, but can lead to overshoot or oscillation." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="I (Integral): " /><Run Text="Addresses accumulated error over time, eliminating steady-state errors. Higher I = eliminates steady-state error faster, but can make the system less stable." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="D (Derivative): " /><Run Text="Dampens the servo's response, reducing overshoot and oscillation. Higher D = smoother response, but can slow down the servo." /></TextBlock>

                        <TextBlock Style="{StaticResource GuideBody}" Margin="0,6,0,8"><Run FontWeight="SemiBold" Text="Min Signal: " /><Run Text="The PWM signal value corresponding to the servo's leftmost position." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Max Signal: " /><Run Text="The PWM signal value corresponding to the servo's rightmost position." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Middle Signal: " /><Run Text="The PWM signal value for the servo's center position. It's generally recommended to leave this at 1500." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Dead Zone: " /><Run Text="How close the servo needs to be to its target before it stops actively trying to reach it. A smaller dead zone means higher precision but may lead to more jitter." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Power: " /><Run Text="Sets the maximum power output to the servo motor. It's expressed as a percentage (e.g., 90% = 450)." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Stall Protection: " /><Run Text="A safety feature that automatically shuts off the servo if it's stalled (blocked from moving) for more than 10 seconds. This helps prevent damage to the servo and electronics." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Ramp Mode: " /><Run Text="Limits the initial current surge when the servo starts up. This helps protect the servo and the device controlling it from damage caused by high current draw." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Total Range: " /><Run Text="The total mechanical travel of the servo (0-320 deg). This is split evenly between the left and right sides. (e.g., 270 deg uses 111 per side, 320 deg uses 130 per side.)" /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}" Margin="0"><Run FontWeight="SemiBold" Text="Direction: " /><Run Text="Allows you to reverse the servo's direction, swapping left and right." /></TextBlock>
                    </StackPanel>
                </Border>

                <!-- Continuous Rotation -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="CONTINUOUS ROTATION MODE" />
                        <TextBlock Style="{StaticResource GuideBody}" Text="Enable the &quot;Continuous rotation&quot; switch to configure the servo for continuous rotation. This automatically sets both Left and Right range to 255." />
                        <TextBlock Style="{StaticResource GuideTerm}" Text="Limitations and features" Margin="0,4,0,4" />
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Full speed only: " /><Run Text="Continuous rotation supports full speed in either direction only. Partial speed control is not available." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}"><Run FontWeight="SemiBold" Text="Home position: " /><Run Text="Sending a position signal of 1500 (or 0.5 in code) returns the servo to its neutral (home) position." /></TextBlock>
                        <TextBlock Style="{StaticResource GuideBody}" Margin="0"><Run FontWeight="SemiBold" Text="Stopping: " /><Run Text="To stop the servo in continuous rotation mode, use the disable-PWM command in your code." /></TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0">
            <Button Content="Close" Style="{StaticResource PrimaryButton}" Margin="20,12" MinWidth="110"
                    HorizontalAlignment="Right" IsCancel="True" Click="Close_Click" />
        </Border>
    </Grid>
</Window>
